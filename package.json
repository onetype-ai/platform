{
    "name": "onetype-sites-app",
    "version": "0.1.0",
    "description": "Visual website editor for OneType Sites.",
    "type": "module",
    "license": "MIT",
    "author": "Dejan Tomic <hi@iamdejan.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/onetype-ai/sites-editor.git"
    },
    "imports": {
        "#auth-service/*": "./back/services/auth/*",
        "#elements-service/*": "./back/services/elements/*",
        "#sites/*": "./back/addons/sites/*",
        "#fonts/*": "./back/addons/fonts/*",
        "#categories/*": "./back/addons/categories/*",
        "#extensions/*": "./back/addons/extensions/*",
        "#pages/*": "./back/addons/sites/addons/pages/*",
        "#sections/*": "./back/addons/sites/addons/sections/*",
        "#elements/*": "./back/addons/sites/addons/elements/*",
        "#variables/*": "./back/addons/sites/addons/variables/*",
        "#installs/*": "./back/addons/extensions/addons/installs/*",
        "#tc-resources/*": "./back/extensions/travel-connect/addons/resources/*",
        "#tc-locations/*": "./back/extensions/travel-connect/addons/locations/*",
        "#tc-directories/*": "./back/extensions/travel-connect/addons/directories/*",
        "#tc-offers/*": "./back/extensions/travel-connect/addons/offers/*"
    },
    "dependencies": {
        "@onetype/framework": "latest"
    }
}
