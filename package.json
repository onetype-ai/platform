{
    "name": "@onetype/platform",
    "version": "0.1.0",
    "description": "Open source workspace platform. Everything is a package, every action is a command, one universal database underneath.",
    "type": "module",
    "exports": {
        ".": "./index.js",
        "./runtimes": "./addons/core/runtimes/back/load.js",
        "./users": "./addons/core/users/back/load.js",
        "./tokens": "./addons/core/tokens/back/load.js",
        "./*": "./*"
    },
    "license": "MIT",
    "author": "Dejan Tomic <hi@iamdejan.com>",
    "repository": {
        "type": "git",
        "url": "https://github.com/onetype-ai/platform.git"
    },
    "imports": {
        "#config/*": "./addons/core/config/back/*",
        "#platform/*": "./back/*",
        "#packages/*": "./addons/core/packages/back/*",
        "#runtimes/*": "./addons/core/runtimes/back/*",
        "#tokens/*": "./addons/core/tokens/back/*",
        "#users/*": "./addons/core/users/back/*"
    },
    "dependencies": {
        "@onetype/framework": "latest"
    }
}
